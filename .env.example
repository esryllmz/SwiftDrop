POSTGRES_HOST_PORT=5439
POSTGRES_CONTAINER_PORT=5432
POSTGRES_USER=swiftdrop_user
POSTGRES_PASSWORD=swiftdrop_password

AUTH_DB_URL=jdbc:postgresql://localhost:5439/swiftdrop_auth_db
LOGISTICS_DB_URL=jdbc:postgresql://localhost:5439/swiftdrop_logistics_db
NOTIFICATION_DB_URL=jdbc:postgresql://localhost:5439/swiftdrop_notification_db

REDIS_HOST=localhost
REDIS_PORT=6379

KAFKA_HOST_PORT=9092
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_RETRY_MAX_ATTEMPTS=3
KAFKA_RETRY_BACKOFF_MS=1000

JWT_SECRET_KEY=replace-with-base64-256-bit-secret
JWT_ACCESS_EXPIRATION_MS=900000
JWT_REFRESH_EXPIRATION_MS=604800000

COOKIE_SECURE=false
COOKIE_SAME_SITE=Lax

ADMIN_SEED_ENABLED=true
ADMIN_SEED_EMAIL=admin@swiftdrop.com
ADMIN_SEED_PASSWORD=change-me
ADMIN_SEED_RESET_EXISTING_PASSWORD=false
ADMIN_SEED_FORCE_ENABLED=true
ADMIN_SEED_FORCE_ROLE_ADMIN=true
ADMIN_SEED_FORCE_PASSWORD_CHANGE=false
# Local Docker compose overrides ADMIN_SEED_RESET_EXISTING_PASSWORD to true for repeatable demos.
# Set ADMIN_SEED_ENABLED=false in real production environments.
SEED_DATA_ENABLED=false
INTERNAL_API_KEY=local-internal-api-key

ONESIGNAL_APP_ID=your-onesignal-app-id
ONESIGNAL_API_KEY=your-onesignal-rest-api-key
ONESIGNAL_MOCK_ENABLED=true
PROCESSED_EVENT_TTL_HOURS=24

FRONTEND_ORIGIN=http://localhost:3000
AUTH_SERVICE_URI=http://localhost:8081
LOGISTICS_SERVICE_URI=http://localhost:8082
NOTIFICATION_SERVICE_URI=http://localhost:8083
MONITORING_TIMEOUT_MS=1500
MONITORING_OUTBOX_PENDING_WARNING_THRESHOLD=10
MONITORING_OUTBOX_AGE_WARNING_SECONDS=60
MONITORING_KAFKA_LAG_WARNING_THRESHOLD=10
PASSWORD_RESET_TOKEN_TTL_MINUTES=15
MAILPIT_SMTP_PORT=1025
MAILPIT_WEB_PORT=8025
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SMTP_AUTH=false
MAIL_SMTP_STARTTLS=false
PASSWORD_RESET_EMAIL_PROVIDER=smtp
PASSWORD_RESET_FROM_ADDRESS=no-reply@swiftdrop.local
PASSWORD_RESET_FROM_NAME=SwiftDrop
PASSWORD_RESET_ONESIGNAL_APP_ID=
PASSWORD_RESET_ONESIGNAL_API_KEY=
